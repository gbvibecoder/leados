# OpenRouter (recommended — single key for all models, free tier available)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override model (default: google/gemini-2.0-flash-exp:free)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# AI Engine priority (openrouter|gemini|anthropic) — default: openrouter > gemini > anthropic
# AI_ENGINE=openrouter

# Anthropic (direct — requires paid API credits)
ANTHROPIC_API_KEY=

# SerpAPI (for Google Trends data)
SERPAPI_KEY=

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# App URL (set to your Vercel/Netlify deployment URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# CRM
HUBSPOT_API_KEY=
GHL_API_KEY=

# Email Outreach
INSTANTLY_API_KEY=
SMARTLEAD_API_KEY=

# LinkedIn Automation (Phantombuster)
PHANTOMBUSTER_API_KEY=
PHANTOMBUSTER_SEARCH_PHANTOM_ID=
PHANTOMBUSTER_CONNECT_PHANTOM_ID=
PHANTOMBUSTER_MESSAGE_PHANTOM_ID=
# LinkedIn session cookie (li_at) — get from browser DevTools > Cookies > linkedin.com
PHANTOMBUSTER_LINKEDIN_COOKIE=

# Voice AI
BLANDAI_API_KEY=
VAPI_API_KEY=

# Ads
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# E-Commerce
SHOPIFY_SHOP_URL=
SHOPIFY_ACCESS_TOKEN=

# Redis (for queues)
REDIS_URL=

# Enrichment
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# Scheduling
CALENDLY_API_KEY=

# AI Image Generation (Fal.ai)
FAL_API_KEY=

# Payments
STRIPE_SECRET_KEY=
